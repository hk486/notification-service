# ─────────────────────────────────────────────────────────────────────────────
# Environment variables consumed by application-prod.yaml
# Copy this file to .env and fill in real values (never commit .env to git).
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:mysql://localhost:3306/notification_service
DATABASE_USER=notification_user
DATABASE_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── AWS SES (Email) ───────────────────────────────────────────────────────────
# Leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY blank when running on EC2/ECS
# with an IAM role — the SDK will pick up the instance-role credentials automatically.
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@yourdomain.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Twilio (SMS) ──────────────────────────────────────────────────────────────
# Find your Account SID and Auth Token at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15005550006

# ── Firebase Cloud Messaging (Push) ──────────────────────────────────────────
# Download the service-account JSON from Firebase Console:
#   Project Settings → Service Accounts → Generate New Private Key
# Then set the path to the downloaded file (or mount it as a secret in K8s/ECS).
FIREBASE_SERVICE_ACCOUNT_PATH=classpath:firebase-service-account.json
